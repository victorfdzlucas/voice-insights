# Copy this to .env and fill in keys (never commit .env)
DATA_DIR=data
BACKEND_BASE_URL=http://localhost:8000

# Required for summaries / sentiment / keywords (all uploads)
OPENAI_API_KEY=

# Optional model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Required for audio uploads (.mp3, .wav, etc.). Not needed if you only upload .txt transcripts.
ASSEMBLYAI_API_KEY=

# Optional: characters shown in UI preview (default 2000)
# TRANSCRIPT_PREVIEW_CHARS=2000
